# Supabase — get from: Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Service role key (secret — never expose to browser)
# Get from: Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# Your deployed site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Random secret for cron job — generate with: openssl rand -hex 32
CRON_SECRET=
